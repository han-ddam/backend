# 운영 서버 .env 예시 (compose.prod.yml 용)
#   서버에서:  cp env.prod.example .env  후 값 채우기
#   위치:      <DEPLOY_DIR>/.env  (예: /home/seoyoon/projects/han-ddam/.env)
#
# ⚠️ 이 파일은 예시(placeholder)만 — 실제 .env 는 절대 커밋 금지.
# ⚠️ host 는 compose 서비스명(postgres/redis), localhost 아님.
# ⚠️ POSTGRES_PASSWORD 와 DATABASE_URL 의 비번은 동일해야 함.
# 강한 값 생성:  openssl rand -hex 24   (특수문자 없어 URL 안전)

# --- 앱 ---
NODE_ENV=production
PORT=3000

# --- DB / Redis (host = compose 서비스명!) ---
DATABASE_URL=postgres://handdam:CHANGE_ME_DB_PASSWORD@postgres:5432/handdam
REDIS_URL=redis://redis:6379

# --- postgres 컨테이너 초기화 (compose 변수 치환에 사용) ---
POSTGRES_USER=handdam
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=handdam

# --- JWT (필수 · 8자↑ · 새로 생성) ---
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- 기타 (기본값 있어 생략 가능) ---
CORS_ORIGINS=*
PROXIMITY_TOLERANCE_M=150

# --- 시드/동기화 쓸 때만 ---
TOURAPI_KEY=

# 배포 시 시드 실행 여부 (1=실행, 그 외/미설정=안 함)
# 1이면 매 배포마다 regions→places 재시드(멱등, 단 관광지는 TourAPI 호출로 수 분).
# 최초 적재/계획된 갱신 때만 1, 평소엔 0 권장. places 시드엔 TOURAPI_KEY 필요.
SEED_ON_DEPLOY=0

# --- 소셜 로그인 (선택) ---
# 카카오/네이버: 클라 토큰 서버검증 → 키 불필요
# 구글: 설정 시 ID token aud 검증 강화 (선택)
# GOOGLE_CLIENT_ID=

# 참고: APP_IMAGE 는 CI(deploy.yml)가 자동 주입하므로 여기 불필요.
# 수동 실행 시에만:  APP_IMAGE=ghcr.io/han-ddam/backend:<tag> docker compose -f compose.prod.yml up -d
