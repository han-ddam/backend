# Copy to .env :  cp env.example .env
# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (PostGIS) ---
# matches docker-compose.yml defaults
DATABASE_URL=postgres://handdam:handdam@localhost:5432/handdam

# --- Redis (cache / rankings / BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- CORS ('*' = 모든 출처 허용, 또는 콤마구분 출처 목록) ---
CORS_ORIGINS=*

# --- Geo / certification policy (Q4 default) ---
PROXIMITY_TOLERANCE_M=150

# --- External (fill per Q7/Q8; ports use fakes until set) ---
# TOURAPI_KEY=
# KAKAO_MOBILITY_KEY=
