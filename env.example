# Copy to .env :  cp env.example .env
# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (PostGIS) ---
# matches docker-compose.yml defaults
DATABASE_URL=postgres://handdam:handdam@localhost:5432/handdam

# --- Redis (cache / rankings / BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- 운영(compose.prod.yml) 전용 — 서버 .env 에만 채움 ---
# postgres 컨테이너 초기화에 사용(POSTGRES_*), DATABASE_URL/REDIS_URL 호스트는 서비스명.
# 비밀번호/시크릿은 dev 기본값 쓰지 말고 새로 생성할 것.
# POSTGRES_USER=handdam
# POSTGRES_PASSWORD=<강한-비번>
# POSTGRES_DB=handdam
# DATABASE_URL=postgres://handdam:<강한-비번>@postgres:5432/handdam
# REDIS_URL=redis://redis:6379

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# 소셜 로그인: 카카오/네이버는 클라가 받은 access token을 서버가 검증(키 불필요).
# 구글은 ID token 검증 시 audience(aud) 확인용 (선택, 설정 시 검증 강화)
# GOOGLE_CLIENT_ID=

# --- CORS ('*' = 모든 출처 허용, 또는 콤마구분 출처 목록) ---
CORS_ORIGINS=*

# --- Geo / certification policy (Q4 default) ---
PROXIMITY_TOLERANCE_M=150

# --- TourAPI (한국관광공사) ---
# data.go.kr 인증키 (Encoding 키 그대로 붙여넣기). seed:regions / ingestion에서 사용
TOURAPI_KEY=
# 선택: areaCode 엔드포인트 (기본 KorService2/areaCode2). 키 버전이 다르면 교체
# TOURAPI_AREACODE_URL=https://apis.data.go.kr/B551011/KorService2/areaCode2
# 선택: areaBasedList 엔드포인트 (seed:places — 관광지 좌표)
# TOURAPI_AREABASED_URL=https://apis.data.go.kr/B551011/KorService2/areaBasedList2
# 선택: 적재할 contentTypeId (기본 12=관광지. 콤마구분 예: 12,14,25)
# TOURAPI_CONTENT_TYPE_IDS=12
# 선택: 페이지당 행수(기본 100) / 타입별 최대 처리수(테스트용)
# TOURAPI_PLACE_ROWS=100
# TOURAPI_PLACE_MAX=50

# --- External (fill later) ---
# KAKAO_MOBILITY_KEY=
